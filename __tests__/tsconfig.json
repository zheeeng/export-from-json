{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["es2015", "es2016", "es2017", "dom"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["jest", "node"],
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
  }
}
